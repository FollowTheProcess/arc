# config
@timeout = 30s
@base = {{ $env.BASE_URL }}
### get-user
# Fetch a user
GET https://example.com/users/{{ $random.int(1, 100) }} HTTP/1.1
Authorization: Bearer {{ token }}
X-Request-Id: {{ $uuid }}
### create-user
POST https://example.com/items
Content-Type: application/json

{"name": "{{ userName }}"}
### import-data
PUT https://example.com/import

<@latin1 ./payload.json
### upload
POST https://example.com/upload
Content-Type: multipart/form-data; boundary=xyz

--xyz
Content-Disposition: form-data; name="file"; filename="input.txt"

< ./input.txt
--xyz

hello world
--xyz--
### find-users
POST https://example.com/find
Content-Type: application/x-www-form-urlencoded

search={{ query }}&sort=desc
